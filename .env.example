TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user ids; leave empty to allow everyone
ALLOWED_USER_IDS=

WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
# ISO 639-1 code or leave empty for auto (overridable with /lang in chat)
WHISPER_LANGUAGE=it
WHISPER_BEAM_SIZE=1
WHISPER_WARMUP_ON_START=1
WHISPER_TIMEOUT_S=900
